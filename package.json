{
  "name": "pos-system-fast-food-edition",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,admin,kds -c blue,green,yellow \"npm run dev --workspace=apps/server\" \"npm run dev --workspace=apps/admin-web\" \"npm run dev --workspace=apps/kds-web\"",
    "db:generate": "npm run db:generate --workspace=packages/db",
    "db:migrate": "npm run db:migrate --workspace=packages/db",
    "db:seed": "npm run db:seed --workspace=packages/db",
    "db:studio": "npm run db:studio --workspace=packages/db",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
